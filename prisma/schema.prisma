generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  readVerses        ReadVerse[]
  completedChapters CompletedChapter[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ReadVerse {
  id      String   @id @default(cuid())
  userId  String
  book    String
  chapter Int
  verse   Int
  readAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, verse])
}

model VerseText {
  id          Int    @id @default(autoincrement())
  book        String
  chapter     Int
  verse       Int
  verseIndex  Int
  text        String
  plainText   String
  firstLetter String
  lastLetter  String

  @@unique([book, chapter, verse])
  @@index([firstLetter, lastLetter])
  @@index([verseIndex])
}

model WordEntry {
  id         Int    @id @default(autoincrement())
  book       String
  chapter    Int
  verse      Int
  verseIndex Int
  wordNum    Int
  word       String
  lemma      String
  morph      String
  plain      String

  @@unique([book, chapter, verse, wordNum])
  @@index([lemma])
  @@index([verseIndex])
  @@index([book, chapter, verse])
}

model CompletedChapter {
  id          String   @id @default(cuid())
  userId      String
  book        String
  chapter     Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter])
}
